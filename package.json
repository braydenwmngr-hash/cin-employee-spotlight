{
  "name": "cinergy-spotlight-production",
  "version": "1.0.0",
  "description": "Cinergy Employee Spotlight digital signage CMS",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "concurrently \"nodemon server.js\" \"vite --host 0.0.0.0\"",
    "build": "vite build",
    "start": "node server.js"
  },
  "engines": {
    "node": ">=20 <27"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "express": "latest",
    "socket.io": "latest",
    "socket.io-client": "latest",
    "jsonwebtoken": "latest",
    "cookie-parser": "latest",
    "multer": "latest",
    "express-rate-limit": "latest",
    "dotenv": "latest",
    "bcryptjs": "latest",
    "uuid": "latest"
  },
  "devDependencies": {
    "concurrently": "latest",
    "nodemon": "latest"
  }
}
